<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="XYZ Bank Test Suite" verbose="2" parallel="none">

    <listeners>
        <listener class-name="io.qameta.allure.testng.AllureTestNg"/>
    </listeners>

    <test name="Login Page Tests">
        <classes>
            <class name="com.xyzbank.tests.LoginPageTest"/>
        </classes>
    </test>

    <test name="Bank Manager Tests">
        <classes>
            <class name="com.xyzbank.tests.BankManagerTest"/>
        </classes>
    </test>

    <test name="Customer Tests">
        <classes>
            <class name="com.xyzbank.tests.CustomerTest"/>
        </classes>
    </test>

</suite>
